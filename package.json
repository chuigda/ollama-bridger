{
  "name": "ollama-openai-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "An Ollama-compatible server that forwards requests to an OpenAI-compatible endpoint.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p .",
    "serve": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0",
    "openai": "^4.80.0",
    "@node-rs/xxhash": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
